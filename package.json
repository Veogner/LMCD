{
  "name": "lmcd",
  "private": true,
  "version": "1.26.1",
  "description": "LMCD - local Minecraft control app.",
  "author": "Local",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env ELECTRON_RUN_AS_NODE= VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "npm run build:renderer && npm run build:electron",
    "build:renderer": "tsc -b && vite build",
    "build:electron": "electron-builder --publish never",
    "gen:icon": "node scripts/gen-icon.js",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:release:win": "npm run build:renderer && electron-builder --win nsis portable --publish never"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "js-yaml": "^4.1.1",
    "pidusage": "^4.0.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.27",
    "electron": "^40.6.1",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "png-to-ico": "^2.1.8",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  },
  "build": {
    "appId": "com.lmcd.app",
    "productName": "LMCD",
    "directories": {
      "buildResources": "build",
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      "server/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico",
      "signAndEditExecutable": false
    },
    "buildVersion": "1.26.1",
    "nsis": {
      "artifactName": "LMCD-1m26c1ea-Setup-${arch}.${ext}",
      "shortcutName": "LMCD",
      "uninstallDisplayName": "LMCD",
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "LMCD-1m26c1ea-Portable-${arch}.${ext}"
    }
  }
}
